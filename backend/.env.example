PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/smart_study_scheduler

# Firebase Admin SDK (download service account JSON from Firebase console)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# Google Calendar OAuth2
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/calendar/callback

# AI Service (FastAPI)
AI_SERVICE_URL=http://localhost:8000

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# JWT (for any additional signing needs)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# CORS
FRONTEND_URL=http://localhost:3000

# Local development without Firebase (NEVER enable in production)
ALLOW_DEV_AUTH=true

# Optional: path to Firebase service account JSON instead of individual vars
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
